{
  "expo": {
    "name": "FitAgent",
    "slug": "fitagent",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "fitagent",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0A",
    "icon": "./src/assets/app-icon-1024.png",
    "splash": {
      "image": "./src/assets/app-icon-1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.abhay.fitagent",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "FitAgent uses speech recognition to log your workouts hands-free.",
        "NSMicrophoneUsageDescription": "FitAgent uses your microphone to listen for voice commands."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/app-icon-1024.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.abhay.fitagent",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "plugins": []
  }
}
